# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Model used for extraction + email drafting. Check docs.claude.com for current
# model strings if this changes: https://docs.claude.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-sonnet-5

# --- Airtable ---
# Personal access token (not the old API key format): https://airtable.com/create/tokens
# Needs scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_PAT=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Opportunities

# --- Pipeline config ---
# Folder scanned for input files (.txt, .pdf, .jpg, .jpeg, .png)
INPUT_FOLDER=data/sample_inputs
# Folder where draft emails + pending-write records get saved for review
OUTPUT_FOLDER=output/drafts
# Fuzzy-match threshold (0-100) above which two items are considered duplicates
DEDUPE_THRESHOLD=85
